# Copy this file to .env.local and fill in real values.
# .env.local is gitignored, so secrets stay off the repo.

# --- Sanity CMS ---
NEXT_PUBLIC_SANITY_PROJECT_ID=dsd23iko
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2021-03-25
# Optional: only needed if you want write access. NEVER commit a real token.
SANITY_TOKEN=

# --- Optional: override hardcoded contract addresses if you redeploy ---
# NEXT_PUBLIC_NFT_COLLECTION_ADDRESS=0x...
# NEXT_PUBLIC_MARKETPLACE_ADDRESS=0x...
